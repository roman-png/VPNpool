#!/bin/sh
# rpcd backend for luci-app-vpnpool. Exposes ubus object "vpnpool".
# Methods: status (read) + control actions (write).
. /usr/libexec/vpnpool/lib.sh 2>/dev/null
CLASH=$(uci -q get vpnpool.main.clash_api); [ -n "$CLASH" ] || CLASH=127.0.0.1:9091

# Tell the running daemon to rebuild config + hot-reload sing-box (manual/domain edits).
# signal_daemon (lib.sh) verifies the pidfile PID is really vpnpoold before signalling.
signal_reload() {
	signal_daemon USR1
}

# Tell the running daemon to re-fetch all sources, then rebuild (source/url edits).
signal_refetch() {
	signal_daemon USR2
}

# Remove ONE node by tag: resolve its link, drop it from whichever list owns it, prune the
# saved/snapshot maps, and (for a pure subscription node) add its link to excluded_node so a
# refetch can't bring it back. STAGES uci changes only — the caller must rebuild_saved_list
# (which commits) and signal_reload. Lets delete_node (one) and delete_nodes (bulk) share the
# logic so a bulk delete does ONE rebuild+reload instead of N sing-box restarts. Returns 1 if
# the tag has no resolvable link.
_delete_one_tag() {   # $1=tag
	local tag="$1" link="" removed=0 LINKS=/etc/vpnpool/links.json MAP
	[ -n "$tag" ] || return 1
	[ -f "$LINKS" ] && link=$(jq -r --arg t "$tag" 'map(select(.tag==$t)) | .[0].link // ""' "$LINKS" 2>/dev/null)
	[ -n "$link" ] || link=$(saved_link_for_tag "$tag")
	[ -n "$link" ] || return 1
	if uci -q get vpnpool.main.manual_node | tr ' ' '\n' | grep -Fxq "$link"; then
		uci del_list vpnpool.main.manual_node="$link"; removed=1
	fi
	if uci -q get vpnpool.main.imported_node | tr ' ' '\n' | grep -Fxq "$link"; then
		uci del_list vpnpool.main.imported_node="$link"; removed=1
		MAP=/etc/vpnpool/imported.map.json
		[ -f "$MAP" ] && { jq --arg l "$link" 'map_values(map(select(. != $l)))' "$MAP" > "$MAP.t" 2>/dev/null && mv "$MAP.t" "$MAP"; }
	fi
	if uci -q get vpnpool.main.active_saved | tr ' ' '\n' | grep -Fxq "$link"; then
		uci del_list vpnpool.main.active_saved="$link"; removed=1
	fi
	# Deleting a node must NOT touch the ⭐ saved archive (saved.map / snapshot.map). The
	# archive is a deliberate "keep forever" store with its own unsave (💾); pruning it here
	# meant a bulk delete could wipe the WHOLE inactive-saved pool. Delete now only removes
	# from the active pool (+ excludes subscription nodes); the archive stays re-activatable.
	if [ "$removed" = 0 ]; then
		uci -q get vpnpool.main.excluded_node | tr ' ' '\n' | grep -Fxq "$link" \
			|| uci add_list vpnpool.main.excluded_node="$link"
	fi
	# Drop any "out of auto-pool" state for this tag so a deleted node leaves that list at
	# once: the force-keep override (keep_auto), the dead set, and its strike counter.
	uci del_list vpnpool.main.keep_auto="$tag" 2>/dev/null
	[ -f /tmp/vpnpool/.dead_tags.json ] && { jq --arg t "$tag" 'map(select(. != $t))' /tmp/vpnpool/.dead_tags.json > /tmp/vpnpool/.dt.t 2>/dev/null && mv /tmp/vpnpool/.dt.t /tmp/vpnpool/.dead_tags.json; }
	[ -f /tmp/vpnpool/.deadstrikes ] && { local TAB; TAB=$(printf '\t'); awk -F"$TAB" -v k="$tag" '$1!=k' /tmp/vpnpool/.deadstrikes > /tmp/vpnpool/.ds.t 2>/dev/null && mv /tmp/vpnpool/.ds.t /tmp/vpnpool/.deadstrikes; }
	return 0
}

case "$1" in
list)
	cat <<'L'
{ "status": {}, "diag": {}, "conntest": {}, "leases": {}, "export": {}, "import": { "config": "x" }, "set_enabled": { "enabled": true }, "select": { "tag": "x" }, "refresh": {}, "ping": {}, "set_url": { "url": "x" }, "del_subscription": {}, "add_source": { "url": "x" }, "del_source": { "url": "x" }, "add_node": { "link": "x" }, "del_node": { "link": "x" }, "import_nodes": { "text": "x" }, "delete_node": { "tag": "x" }, "delete_nodes": { "tags": [] }, "restore_node": { "tag": "x" }, "refilter_node": { "tag": "x" }, "save_node": { "tag": "x" }, "unsave_node": { "tag": "x" }, "activate_saved": { "tag": "x" }, "deactivate_saved": { "tag": "x" }, "node_link": { "tag": "x" }, "export_nodes": { "scope": "x" }, "add_sub": { "url": "x" }, "del_sub": { "url": "x" }, "unlock": { "tag": "x" }, "unlock_result": {}, "add_auto_domain": { "domain": "x" }, "del_auto_domain": { "domain": "x" }, "run_adaptive": {}, "set_domains": { "domains": [] }, "set_communities": { "communities": [] }, "set_option": { "name": "x", "value": "y" }, "set_clients": { "mode": "all", "clients": [], "devices": [] }, "set_auto_members": { "members": [] }, "set_preferred": { "tag": "x" }, "set_schedule": { "enabled": true, "on": "x", "off": "x", "refresh": "x" }, "speedtest": { "tag": "x" }, "speedtest_result": {}, "probe_source": { "url": "x" }, "probe_result": {}, "import_select": { "url": "x", "idx": [] }, "tg_test": {} }
L
	;;
call)
	input="$(cat)"
	case "$2" in
	status)
		/usr/libexec/vpnpool/status.sh
		;;
	diag)
		/usr/libexec/vpnpool/diag.sh
		;;
	export)
		cfg=$(uci export vpnpool 2>/dev/null)
		jq -n --arg c "$cfg" '{ config: $c }'
		;;
	import)
		cfg=$(echo "$input" | jq -r '.config // ""')
		if [ -n "$cfg" ]; then
			printf '%s\n' "$cfg" | uci import vpnpool 2>/dev/null
			uci commit vpnpool
			signal_refetch
			echo '{"ok":true}'
		else
			echo '{"error":"empty config"}'
		fi
		;;
	conntest)
		# Exit-IP test through the tunnel. Try SEVERAL IP-echo endpoints, not just one — a
		# single service (ifconfig.co) frequently blocks/ratelimits datacenter exit IPs, which
		# made a perfectly working tunnel report "exit test failed / service not running".
		# Succeeds on the first endpoint that returns an IP. Different JSON shapes are parsed
		# generically (ip/ip_addr/query, country/country_iso/country_code).
		TP=$(uci -q get vpnpool.main.test_port); [ -n "$TP" ] || TP=1605
		IP=""; CO=""
		for url in "https://ifconfig.co/json" "https://ipinfo.io/json" "https://api.ip.sb/geoip" "https://api.ipify.org?format=json"; do
			J=$(curl -s -m 7 --proxy "socks5h://127.0.0.1:$TP" "$url" 2>/dev/null)
			[ -n "$J" ] || continue
			IP=$(echo "$J" | jq -r '(.ip // .ip_addr // .query // "") | tostring' 2>/dev/null)
			[ -n "$IP" ] && [ "$IP" != "null" ] || { IP=""; continue; }
			CO=$(echo "$J" | jq -r '(.country_iso // .country_code // .country // "") | tostring' 2>/dev/null); [ "$CO" = "null" ] && CO=""
			break
		done
		jq -n --arg ip "$IP" --arg co "$CO" '{ ok: ($ip != ""), ip: $ip, country: $co }'
		;;
	leases)
		# Current DHCP leases for the device picker in per-client routing.
		# /tmp/dhcp.leases columns: <expiry> <mac> <ip> <hostname> <clientid>.
		# Read-only. MUST emit a JSON OBJECT — rpcd's exec plugin rejects a top-level
		# array with INVALID_ARGUMENT — so wrap the list as { leases: [{mac,ip,host}] }.
		# hostname "*" -> "" so the UI falls back to showing the IP.
		awk '{print $2" "$3" "$4}' /tmp/dhcp.leases 2>/dev/null \
			| jq -R -s '{ leases: (split("\n")|map(select(length>0)|split(" ")
				|{mac:(.[0]//""), ip:(.[1]//""), host:((.[2]//"") | if .=="*" then "" else . end)})
				|map(select(.mac!="" and .ip!=""))) }' 2>/dev/null || echo '{"leases":[]}'
		;;
	set_enabled)
		en=$(echo "$input" | jq -r '.enabled')
		if [ "$en" = "true" ] || [ "$en" = "1" ]; then
			uci set vpnpool.main.enabled='1'; uci commit vpnpool
			/etc/init.d/vpnpool enable; /etc/init.d/vpnpool restart
		else
			uci set vpnpool.main.enabled='0'; uci commit vpnpool
			/etc/init.d/vpnpool stop; /etc/init.d/vpnpool disable
		fi
		echo '{"ok":true}'
		;;
	select)
		tag=$(echo "$input" | jq -r '.tag')
		# persist the pick so it survives reload / subscription updates ('auto' clears it)
		if [ "$tag" = "auto" ]; then
			uci set vpnpool.main.selected_node=''
		else
			uci set vpnpool.main.selected_node="$tag"
		fi
		uci commit vpnpool
		code=$(curl -s -o /dev/null -w '%{http_code}' -X PUT "http://$CLASH/proxies/proxy" \
			--data "$(jq -n --arg n "$tag" '{name:$n}')")
		echo "{\"ok\":true,\"http\":\"$code\"}"
		;;
	refresh)
		if [ "$(uci -q get vpnpool.main.enabled)" = "1" ]; then
			/etc/init.d/vpnpool restart
		fi
		echo '{"ok":true}'
		;;
	ping)
		# Dashboard ping reflects the PRIMARY check service, so the shown delay means
		# "this node actually reaches the wanted service" — not just some CDN.
		HU=$(check_probe_urls 2>/dev/null | head -n1); [ -n "$HU" ] || HU=http://cp.cloudflare.com/generate_204
		ENCU=$(jq -rn --arg s "$HU" '$s|@uri')
		jq -r '.[].tag' /tmp/vpnpool/nodes.json 2>/dev/null | while read -r tag; do
			[ -n "$tag" ] || continue
			enc=$(jq -rn --arg s "$tag" '$s|@uri')
			curl -s -m 7 "http://$CLASH/proxies/$enc/delay?url=$ENCU&timeout=5000" >/dev/null 2>&1 &
		done
		wait
		# Fold the dead-node e2e filter into the ping: kick off a SEQUENTIAL quality
		# sweep in the background (self-guarded against concurrent runs). It updates
		# .dead_tags.json and signals the daemon (USR1) to rebuild ONLY if the dead set
		# changed — so no rebuild/bounce unless a node actually went dead/recovered.
		[ "$(uci -q get vpnpool.main.dead_filter)" != "0" ] && \
			setsid sh -c '/usr/libexec/vpnpool/nodecheck.sh' >/dev/null 2>&1 &
		echo '{"ok":true}'
		;;
	set_url)
		u=$(echo "$input" | jq -r '.url // ""')
		uci set vpnpool.main.subscription_url="$u"; uci commit vpnpool
		signal_refetch
		echo '{"ok":true}'
		;;
	del_subscription)
		# Promote EVERY saved (archived) node into the live pool BEFORE dropping the
		# subscription — otherwise deleting the sub would empty the pool and kill the
		# tunnel. saved_archive_json = manual ⭐ UNION auto-snapshot; add each link to
		# active_saved (deduped). The subsequent refetch rebuilds with no primary sub but
		# WITH these promoted nodes, so connectivity survives the deletion.
		saved_archive_json 2>/dev/null | jq -r '.[].link // empty' 2>/dev/null | while IFS= read -r l; do
			[ -n "$l" ] || continue
			uci -q get vpnpool.main.active_saved | tr ' ' '\n' | grep -Fxq "$l" && continue
			uci add_list vpnpool.main.active_saved="$l"
		done
		uci -q delete vpnpool.main.subscription_url
		# Clear the manual node-exclude list too — it only held links from THIS
		# subscription's nodes (hidden via the dashboard ✕); with the subscription gone
		# they're meaningless, so a future subscription starts with a clean slate.
		uci -q delete vpnpool.main.excluded_node
		uci commit vpnpool
		rm -f /etc/vpnpool/sub.expire /etc/vpnpool/sub.usage
		# Drop the cached subscription nodes so they LEAVE the dashboard. Without this,
		# fetch.sh's offline-cache fallback (no URL -> 0 fetched -> restore cache) would
		# repopulate the OLD subscription nodes. Saved nodes survive (promoted to
		# active_saved above); manual/imported are their own lists; extra_sub re-fetch.
		rm -rf /etc/vpnpool/sources_cache /tmp/vpnpool/sources
		signal_refetch
		promoted=$(uci -q get vpnpool.main.active_saved 2>/dev/null | tr ' ' '\n' | grep -c '://')
		jq -n --argjson p "${promoted:-0}" '{ok:true, promoted:$p}'
		;;
	add_source)
		u=$(echo "$input" | jq -r '.url // ""')
		# dedup: a double-click / repeat must not add the same source twice (URLs have no spaces)
		if [ -n "$u" ] && ! uci -q get vpnpool.main.source | tr ' ' '\n' | grep -Fxq "$u"; then
			uci add_list vpnpool.main.source="$u"; uci commit vpnpool
		fi
		echo '{"ok":true}'
		;;
	probe_source)
		# Fetch + parse + ICMP-ping one URL. On a slow (mips) router this can exceed
		# rpcd's exec timeout, so run it in the BACKGROUND and let the UI poll
		# probe_result. Read-only w.r.t. the live config.
		u=$(echo "$input" | jq -r '.url // ""')
		[ -n "$u" ] || { echo '{"error":"no url"}'; exit 0; }
		mkdir -p /tmp/vpnpool
		clear_stale_lock /tmp/vpnpool/.probe-running 180   # don't let a killed probe block forever
		if [ -f /tmp/vpnpool/.probe-running ]; then echo '{"running":true,"already":true}'; exit 0; fi
		: > /tmp/vpnpool/.probe-running
		rm -f /tmp/vpnpool/.probe-result.json
		setsid sh -c '/usr/libexec/vpnpool/probe.sh "$1" > /tmp/vpnpool/.probe-result.json 2>/dev/null; rm -f /tmp/vpnpool/.probe-running' _ "$u" >/dev/null 2>&1 &
		echo $! > /tmp/vpnpool/.probe-running   # record worker PID -> clear_stale_lock frees it the instant it dies
		echo '{"running":true,"started":true}'
		;;
	probe_result)
		if [ -f /tmp/vpnpool/.probe-running ]; then
			echo '{"running":true}'
		elif [ -f /tmp/vpnpool/.probe-result.json ]; then
			jq '. + {running:false}' /tmp/vpnpool/.probe-result.json 2>/dev/null || echo '{"running":false,"error":"bad result","nodes":[]}'
		else
			echo '{"running":false,"nodes":[]}'
		fi
		;;
	import_select)
		# The UI sends only { url, idx:[picked indices] }. We resolve those indices to
		# links from the server-side probe cache (probe.sh wrote it), so the browser
		# never uploads hundreds of links (that large request never reached rpcd).
		# imported_node := (current - scopeOfThisSource) + picked, so re-probing
		# ("Update") and re-selecting cleanly replaces just this source's contribution.
		u=$(echo "$input" | jq -r '.url // ""')
		CACHE=/tmp/vpnpool/.probe-cache.json
		MAP=/etc/vpnpool/imported.map.json
		mkdir -p /etc/vpnpool; [ -f "$MAP" ] || echo '{}' > "$MAP"
		# resolve picked indices -> links from the probe cache (must be for this url)
		SEL='[]'
		if [ -f "$CACHE" ] && [ "$(jq -r '.url // ""' "$CACHE" 2>/dev/null)" = "$u" ]; then
			SEL=$(jq -c --argjson ix "$(echo "$input" | jq -c '.idx // []')" \
				'[ .nodes[] | select(.i as $i | $ix | index($i)) | .link ] | map(select(. != null and . != ""))' "$CACHE")
		fi
		# store this source's picks (replaces its previous set), then regenerate the
		# flat imported_node list as the unique union of every source's links.
		jq --arg u "$u" --argjson sel "$SEL" '.[$u] = $sel' "$MAP" > "$MAP.tmp" 2>/dev/null && mv "$MAP.tmp" "$MAP"
		uci -q delete vpnpool.main.imported_node
		jq -r '[.[][]] | unique | .[]' "$MAP" 2>/dev/null | while IFS= read -r l; do
			[ -n "$l" ] && uci add_list vpnpool.main.imported_node="$l"
		done
		if [ -n "$u" ] && ! uci -q get vpnpool.main.source | tr ' ' '\n' | grep -Fxq "$u"; then
			uci add_list vpnpool.main.source="$u"
		fi
		uci commit vpnpool
		signal_reload
		echo "{\"ok\":true,\"count\":$(echo "$SEL" | jq 'length')}"
		;;
	del_source)
		# forget the source URL AND drop the nodes imported from it (they must leave
		# the pool / dashboard, not linger).
		u=$(echo "$input" | jq -r '.url // ""')
		MAP=/etc/vpnpool/imported.map.json
		if [ -n "$u" ]; then
			uci del_list vpnpool.main.source="$u" 2>/dev/null
			[ -f "$MAP" ] && { jq --arg u "$u" 'del(.[$u])' "$MAP" > "$MAP.tmp" 2>/dev/null && mv "$MAP.tmp" "$MAP"; }
			uci -q delete vpnpool.main.imported_node
			[ -f "$MAP" ] && jq -r '[.[][]] | unique | .[]' "$MAP" 2>/dev/null | while IFS= read -r l; do
				[ -n "$l" ] && uci add_list vpnpool.main.imported_node="$l"
			done
			uci commit vpnpool
			signal_reload
		fi
		echo '{"ok":true}'
		;;
	set_communities)
		uci -q delete vpnpool.routing.community
		echo "$input" | jq -r '.communities[]? // empty' | while read -r c; do
			[ -n "$c" ] && uci add_list vpnpool.routing.community="$c"
		done
		uci commit vpnpool
		signal_reload
		echo '{"ok":true}'
		;;
	set_auto_members)
		# Which node tags take part in urltest auto-switching. Empty list = ALL
		# nodes (default; future nodes auto-join). A non-empty list pins the pool.
		uci -q delete vpnpool.main.auto_member
		echo "$input" | jq -r '.members[]? // empty' | while read -r m; do
			[ -n "$m" ] && uci add_list vpnpool.main.auto_member="$m"
		done
		uci commit vpnpool
		signal_reload
		echo '{"ok":true}'
		;;
	set_preferred)
		# Preferred-node soft pin, set straight from the dashboard (📌). Toggle: pinning
		# the already-preferred node (or an empty tag) clears it back to auto. Setting a
		# new preferred node also releases any HARD manual pin (selected_node) so the soft
		# pin can actually take over. No signal_reload: preferred_node is read live by the
		# daemon's preferred_check, which switches the running selector via the clash API
		# within one supervise tick — so the tunnel is never bounced just to pin a node.
		t=$(echo "$input" | jq -r '.tag // ""')
		cur=$(uci -q get vpnpool.main.preferred_node)
		if [ -z "$t" ] || [ "$t" = "$cur" ]; then
			uci -q delete vpnpool.main.preferred_node
		else
			uci set vpnpool.main.preferred_node="$t"
			uci -q delete vpnpool.main.selected_node
		fi
		uci commit vpnpool
		echo '{"ok":true}'
		;;
	set_clients)
		# Per-client routing. clients[] = raw IPv4 (typed manually); devices[] = MAC
		# addresses (picked by DHCP name). MACs are stable across DHCP renewals, so a
		# device stays matched even when its IP changes — route.sh builds an @clients
		# (ip) set and an @clients_mac (ether) set, a host matches if EITHER hits.
		m=$(echo "$input" | jq -r '.mode // "all"')
		uci set vpnpool.main.client_mode="$m"
		uci -q delete vpnpool.main.client
		echo "$input" | jq -r '.clients[]? // empty' | while read -r c; do
			[ -n "$c" ] && uci add_list vpnpool.main.client="$c"
		done
		uci -q delete vpnpool.main.client_dev
		echo "$input" | jq -r '.devices[]? // empty' | while read -r d; do
			[ -n "$d" ] && uci add_list vpnpool.main.client_dev="$d"
		done
		uci commit vpnpool
		signal_reload
		echo '{"ok":true}'
		;;
	set_option)
		k=$(echo "$input" | jq -r '.name // ""')
		v=$(echo "$input" | jq -r '.value // ""')
		case "$k" in
		failover_interval|failover_tolerance|subscription_interval|auto_switch|mode|health_url|check_services|subscription_ua|telegram_enabled|telegram_token|telegram_chat|telegram_control|telegram_via_proxy|ipv6|killswitch|dns_protect|preferred_node|auto_snapshot|auto_snapshot_max|antidpi|adaptive_routing|adaptive_max_per_run|dead_filter|dead_filter_strikes|dead_filter_tries)
			# Server-side clamp for numeric options: never store a non-numeric/out-of-range
			# value (the UI also surfaces this, but the backend must not trust the client).
			case "$k" in
			failover_interval)    case "$v" in (''|*[!0-9]*) v=60 ;; esac; [ "$v" -lt 10 ] && v=10 ;;
			failover_tolerance)   case "$v" in (''|*[!0-9]*) v=50 ;; esac; [ "$v" -gt 5000 ] && v=5000 ;;
			dead_filter_strikes)  case "$v" in (''|*[!0-9]*) v=3 ;; esac;  [ "$v" -lt 1 ] && v=1 ;;
			dead_filter_tries)    case "$v" in (''|*[!0-9]*) v=3 ;; esac;  [ "$v" -lt 1 ] && v=1; [ "$v" -gt 10 ] && v=10 ;;
			ipv6)                 case "$v" in block|off) ;; *) v=block ;; esac ;;   # 'proxy' mode removed -> safe default
			antidpi)              case "$v" in off|on|aggressive) ;; 0) v=off ;; 1) v=on ;; *) v=off ;; esac ;;   # 3-way + legacy 0/1
			auto_snapshot_max)    case "$v" in (''|*[!0-9]*) v=20 ;; esac; [ "$v" -lt 1 ] && v=1; [ "$v" -gt 1000 ] && v=1000 ;;
			adaptive_max_per_run) case "$v" in (''|*[!0-9]*) v=8 ;; esac;  [ "$v" -lt 1 ] && v=1; [ "$v" -gt 50 ] && v=50 ;;
			esac
			uci set vpnpool.main."$k"="$v"; uci commit vpnpool
			# check_services changes the urltest probe URL -> needs a rebuild (falls into
			# the default signal_reload below). dead_filter* are read live by nodecheck.sh.
			case "$k" in
				subscription_interval|telegram_*|preferred_node|auto_snapshot|auto_snapshot_max|adaptive_max_per_run|dead_filter|dead_filter_strikes|dead_filter_tries) : ;;   # read live by the daemon, no reload
				*) signal_reload ;;
			esac
			echo '{"ok":true}'
			;;
		*)
			echo '{"error":"unknown option"}'
			;;
		esac
		;;
	tg_test)
		code=$(tg_send "✅ vpnpool: test message" 2>/dev/null)
		if [ "$code" = "200" ]; then
			echo '{"ok":true}'
		else
			echo "{\"ok\":false,\"http\":\"${code:-000}\"}"
		fi
		;;
	add_node)
		l=$(echo "$input" | jq -r '.link // ""')
		# dedup: a double-click must not add the same node twice (links have no spaces)
		if [ -n "$l" ] && ! uci -q get vpnpool.main.manual_node | tr ' ' '\n' | grep -Fxq "$l"; then
			uci add_list vpnpool.main.manual_node="$l"; uci commit vpnpool; signal_reload
		fi
		echo '{"ok":true}'
		;;
	del_node)
		l=$(echo "$input" | jq -r '.link // ""')
		[ -n "$l" ] && { uci del_list vpnpool.main.manual_node="$l"; uci commit vpnpool; signal_reload; }
		echo '{"ok":true}'
		;;
	import_nodes)
		# Bulk-import nodes by pasted text OR an uploaded file (the browser reads the
		# file and sends its text here). Accepts a list of node links (one per line) OR
		# a whole base64 subscription blob. We DON'T decode/parse in the shell — we hand
		# the raw text to parser.uc (the SAME parser the build uses): it auto-detects a
		# base64 subscription vs a plain link list, normalises each node, and with
		# --keep-link returns the original vless:// (vmess/trojan/ss/…) link. This avoids
		# any dependency on a `base64` applet (absent on tiny busybox builds) and the
		# whitespace-split bug (links are one-per-line; tags may contain spaces). Every
		# resulting link is added to the persistent manual_node list, deduped.
		txt=$(echo "$input" | jq -r '.text // ""')
		[ -n "$txt" ] || { echo '{"ok":false,"error":"empty"}'; exit 0; }
		mkdir -p /tmp/vpnpool
		RAW=/tmp/vpnpool/.import.raw
		printf '%s\n' "$txt" > "$RAW"
		TMP=/tmp/vpnpool/.import.links
		ucode /usr/libexec/vpnpool/parser.uc --keep-link "$RAW" 2>/dev/null \
			| jq -r '.[]?._link // empty' 2>/dev/null \
			| awk 'NF && !seen[$0]++' > "$TMP"
		rm -f "$RAW"
		if [ ! -s "$TMP" ]; then rm -f "$TMP"; echo '{"ok":false,"error":"no node links found"}'; exit 0; fi
		added=0
		while IFS= read -r l; do
			[ -n "$l" ] || continue
			if uci -q get vpnpool.main.manual_node | tr ' ' '\n' | grep -Fxq "$l"; then :; else
				uci add_list vpnpool.main.manual_node="$l" && added=$((added + 1))
			fi
		done < "$TMP"
		rm -f "$TMP"
		if [ "$added" -gt 0 ]; then uci commit vpnpool; signal_reload; fi
		total=$(uci -q get vpnpool.main.manual_node 2>/dev/null | tr ' ' '\n' | grep -c '://')
		jq -n --argjson a "$added" --argjson t "${total:-0}" '{ok:true, added:$a, total:$t}'
		;;
	delete_node)
		# Manual node removal from the dashboard ✕. Resolve the node's link by tag, then
		# remove it from whichever list owns it. A pure SUBSCRIPTION node has no own list,
		# so we add its link to excluded_node — build.sh filters those out every build, so
		# a refetch can't bring it back. (excluded_node is wiped on del_subscription.)
		tag=$(echo "$input" | jq -r '.tag // ""')
		[ -n "$tag" ] || { echo '{"ok":false,"error":"no tag"}'; exit 0; }
		if _delete_one_tag "$tag"; then
			rebuild_saved_list      # commits vpnpool (incl. the staged del_lists)
			signal_reload
			echo '{"ok":true}'
		else
			echo '{"ok":false,"error":"no link for tag"}'
		fi
		;;
	delete_nodes)
		# Bulk delete: stage every removal, then do ONE rebuild + ONE reload at the end.
		# Deleting N nodes one-by-one fired N signal_reloads = N sing-box restarts in a row
		# (tunnel flapping). Tags can contain spaces, so read one-per-line (never split).
		echo "$input" | jq -r '.tags[]? // empty' | while IFS= read -r t; do
			[ -n "$t" ] && _delete_one_tag "$t"
		done
		rebuild_saved_list      # commits all staged del_lists/excludes from the loop
		signal_reload
		echo '{"ok":true}'
		;;
	restore_node)
		# Manual override of the service-accuracy dead-filter: force this node BACK into the
		# auto pool and keep it there even if the service check keeps failing. Adds its tag
		# to the keep_auto whitelist (which nodecheck.sh skips, so it never re-enters
		# .dead_tags.json), prunes it from the current dead set + strike counter, and
		# rebuilds so it rejoins auto immediately. The TCP prefilter still applies, so a
		# truly TCP-dead node won't be forced into the pool (no hung-socket regression).
		tag=$(echo "$input" | jq -r '.tag // ""')
		[ -n "$tag" ] || { echo '{"ok":false,"error":"no tag"}'; exit 0; }
		exists=0
		. /lib/functions.sh 2>/dev/null
		__ck() { [ "$1" = "$tag" ] && exists=1; }
		config_load vpnpool 2>/dev/null
		config_list_foreach main keep_auto __ck 2>/dev/null
		[ "$exists" = 1 ] || { uci add_list vpnpool.main.keep_auto="$tag"; uci commit vpnpool; }
		DEAD=/tmp/vpnpool/.dead_tags.json
		[ -f "$DEAD" ] && { jq --arg t "$tag" 'map(select(. != $t))' "$DEAD" > "$DEAD.t" 2>/dev/null && mv "$DEAD.t" "$DEAD"; }
		STRK=/tmp/vpnpool/.deadstrikes
		[ -f "$STRK" ] && { TAB=$(printf '\t'); awk -F"$TAB" -v k="$tag" '$1!=k' "$STRK" > "$STRK.t" 2>/dev/null && mv "$STRK.t" "$STRK"; }
		signal_reload
		echo '{"ok":true}'
		;;
	refilter_node)
		# Undo restore_node: drop the tag from keep_auto so the service-accuracy filter can
		# demote it again. Rebuild so the pool reflects the current dead set.
		tag=$(echo "$input" | jq -r '.tag // ""')
		[ -n "$tag" ] || { echo '{"ok":false,"error":"no tag"}'; exit 0; }
		uci del_list vpnpool.main.keep_auto="$tag" 2>/dev/null
		uci commit vpnpool
		signal_reload
		echo '{"ok":true}'
		;;
	save_node)
		# persist a subscription node into the separate "saved" store so it stays
		# available after the subscription expires. Resolve tag -> original link
		# from the build-time map, keep a tag->link map, regenerate the uci list.
		tag=$(echo "$input" | jq -r '.tag // ""')
		MAP=/etc/vpnpool/saved.map.json
		LINKS=/etc/vpnpool/links.json
		mkdir -p /etc/vpnpool; [ -f "$MAP" ] || echo '{}' > "$MAP"
		link=""
		[ -f "$LINKS" ] && link=$(jq -r --arg t "$tag" 'map(select(.tag==$t)) | .[0].link // ""' "$LINKS" 2>/dev/null)
		if [ -n "$tag" ] && [ -n "$link" ]; then
			jq --arg t "$tag" --arg l "$link" '.[$t]=$l' "$MAP" > "$MAP.tmp" 2>/dev/null && mv "$MAP.tmp" "$MAP"
			# Saving only updates the INACTIVE archive — it does NOT change the live
			# sing-box config, so NO signal_reload here (that full rebuild is what made
			# the ⭐ feel laggy/flaky and needlessly bounced the tunnel). rebuild_saved_list
			# refreshes the uci saved_node archive list for export; the dashboard star
			# reflects the map write immediately on the next status poll.
			rebuild_saved_list
			echo '{"ok":true}'
		else
			echo '{"ok":false,"error":"no link for tag"}'
		fi
		;;
	unsave_node)
		# remove from BOTH the manual map and the auto-snapshot map, so an unsaved
		# node doesn't immediately reappear on the next snapshot. If it was promoted
		# into the live pool (active_saved), drop it there too (that DOES need a reload).
		tag=$(echo "$input" | jq -r '.tag // ""')
		MAP=/etc/vpnpool/saved.map.json
		[ -f "$MAP" ] || echo '{}' > "$MAP"
		link=$(saved_link_for_tag "$tag")
		jq --arg t "$tag" 'del(.[$t])' "$MAP" > "$MAP.tmp" 2>/dev/null && mv "$MAP.tmp" "$MAP"
		[ -f "$SNAP_MAP" ] && { jq --arg t "$tag" 'del(.[$t])' "$SNAP_MAP" > "$SNAP_MAP.tmp" 2>/dev/null && mv "$SNAP_MAP.tmp" "$SNAP_MAP"; }
		reload=0
		if [ -n "$link" ] && uci -q get vpnpool.main.active_saved | tr ' ' '\n' | grep -Fxq "$link"; then
			uci del_list vpnpool.main.active_saved="$link"; reload=1
		fi
		rebuild_saved_list                      # commits vpnpool (incl. the del_list above)
		[ "$reload" = 1 ] && signal_reload
		echo '{"ok":true}'
		;;
	activate_saved)
		# promote an archived (inactive) saved node into the live active pool.
		tag=$(echo "$input" | jq -r '.tag // ""')
		link=$(saved_link_for_tag "$tag")
		if [ -n "$link" ]; then
			# If this node had been deleted (its link excluded), un-exclude it so activating
			# the saved copy actually brings it back — otherwise build.sh would filter it out.
			uci del_list vpnpool.main.excluded_node="$link" 2>/dev/null
			if uci -q get vpnpool.main.active_saved | tr ' ' '\n' | grep -Fxq "$link"; then uci commit vpnpool; signal_reload; else
				uci add_list vpnpool.main.active_saved="$link"; uci commit vpnpool; signal_reload
			fi
			echo '{"ok":true}'
		else
			echo '{"ok":false,"error":"no link for tag"}'
		fi
		;;
	deactivate_saved)
		# demote a promoted saved node back to the inactive archive (stays saved).
		tag=$(echo "$input" | jq -r '.tag // ""')
		link=$(saved_link_for_tag "$tag")
		[ -n "$link" ] || link=$(jq -r --arg t "$tag" 'map(select(.tag==$t)) | .[0].link // ""' /etc/vpnpool/links.json 2>/dev/null)
		if [ -n "$link" ]; then
			uci del_list vpnpool.main.active_saved="$link" 2>/dev/null; uci commit vpnpool; signal_reload
		fi
		echo '{"ok":true}'
		;;
	node_link)
		# return the original vless:// (etc.) link for a node tag, for share/QR.
		# Falls back to the saved archive so inactive saved nodes can still be shared.
		tag=$(echo "$input" | jq -r '.tag // ""')
		LINKS=/etc/vpnpool/links.json
		link=""
		[ -f "$LINKS" ] && link=$(jq -r --arg t "$tag" 'map(select(.tag==$t)) | .[0].link // ""' "$LINKS" 2>/dev/null)
		[ -n "$link" ] || link=$(saved_link_for_tag "$tag")
		jq -n --arg l "$link" '{ ok: ($l != ""), link: $l }'
		;;
	export_nodes)
		# export a set of node links as a JSON array (the browser turns it into a
		# base64 subscription). scope: saved | manual | imported | all.
		scope=$(echo "$input" | jq -r '.scope // "all"')
		LINKS=/etc/vpnpool/links.json
		SAVEDMAP=/etc/vpnpool/saved.map.json
		case "$scope" in
		saved)
			# the canonical saved set = manual stars (saved.map) UNION auto-snapshot
			# (snapshot.map), already merged into the uci saved_node list by
			# rebuild_saved_list — the SAME set the dashboard marks with a star. Reading
			# only saved.map.json here missed every auto-snapshot node (export showed
			# "none" while stars were visible). Links are URLs (no spaces) -> safe to split.
			uci -q get vpnpool.main.saved_node | tr ' ' '\n' | grep '://' | jq -R . | jq -s 'unique' 2>/dev/null || echo '[]'
			;;
		manual|imported)
			opt=$([ "$scope" = manual ] && echo manual_node || echo imported_node)
			uci -q get vpnpool.main."$opt" | tr ' ' '\n' | grep '://' | jq -R . | jq -s '.' 2>/dev/null || echo '[]'
			;;
		*)
			[ -f "$LINKS" ] && jq -c '[.[].link] | map(select(. != null and . != "")) | unique' "$LINKS" 2>/dev/null || echo '[]'
			;;
		esac | jq -c '{ ok: ((.|length) > 0), links: . }'
		;;
	add_sub)
		# extra FULL subscription (bulk-merged into the pool, unlike probe-only sources).
		# Add (dedup) + trigger the daemon's full refetch, THEN do one quick validation fetch
		# so the UI can report immediately whether the URL is reachable and how many nodes it
		# yields — otherwise a typo / unreachable port (e.g. a panel port blocked from the
		# router) silently adds nothing and looks like a bug. parser.uc auto-detects
		# base64/JSON/link-list. Short timeout keeps us inside the rpcd call budget; the
		# daemon's signal_refetch does the full multi-UA merge in the background.
		u=$(echo "$input" | jq -r '.url // ""')
		[ -n "$u" ] || { echo '{"ok":false,"error":"no url"}'; exit 0; }
		if ! uci -q get vpnpool.main.extra_sub | tr ' ' '\n' | grep -Fxq "$u"; then
			uci add_list vpnpool.main.extra_sub="$u"; uci commit vpnpool; signal_refetch
		fi
		mkdir -p /tmp/vpnpool
		B=/tmp/vpnpool/.subcheck.raw
		code=$(curl -sfL --connect-timeout 4 -m 9 -A 'v2rayNG/1.9.5' "$u" -o "$B" -w '%{http_code}' 2>/dev/null)
		cnt=0
		[ -s "$B" ] && cnt=$(ucode /usr/libexec/vpnpool/parser.uc "$B" 2>/dev/null | jq 'length' 2>/dev/null)
		case "$cnt" in (''|*[!0-9]*) cnt=0 ;; esac
		rm -f "$B"
		jq -n --argjson n "$cnt" --arg http "${code:-000}" '{ok:true, fetched:$n, http:$http}'
		;;
	del_sub)
		u=$(echo "$input" | jq -r '.url // ""')
		[ -n "$u" ] && { uci del_list vpnpool.main.extra_sub="$u" 2>/dev/null; uci commit vpnpool; signal_refetch; }
		echo '{"ok":true}'
		;;
	set_schedule)
		en=$(echo "$input" | jq -r '.enabled')
		on=$(echo "$input" | jq -r '.on // ""')
		off=$(echo "$input" | jq -r '.off // ""')
		ref=$(echo "$input" | jq -r '.refresh // ""')
		if [ "$en" = "true" ] || [ "$en" = "1" ]; then uci set vpnpool.main.sched_enabled='1'; else uci set vpnpool.main.sched_enabled='0'; fi
		uci set vpnpool.main.sched_on="$on"
		uci set vpnpool.main.sched_off="$off"
		uci set vpnpool.main.sched_refresh="$ref"
		uci commit vpnpool
		/usr/libexec/vpnpool/sched.sh apply >/dev/null 2>&1
		echo '{"ok":true}'
		;;
	unlock)
		# per-node service-unblock test — background (flips egress briefly), poll unlock_result.
		tag=$(echo "$input" | jq -r '.tag // ""')
		[ -n "$tag" ] || { echo '{"error":"no tag"}'; exit 0; }
		mkdir -p /tmp/vpnpool
		clear_stale_lock /tmp/vpnpool/.unlock-running 180   # don't let a killed unlock block forever
		if [ -f /tmp/vpnpool/.unlock-running ]; then echo '{"running":true,"already":true}'; exit 0; fi
		: > /tmp/vpnpool/.unlock-running
		rm -f /tmp/vpnpool/.unlock-result.json
		setsid sh -c '/usr/libexec/vpnpool/unlock.sh "$1"; rm -f /tmp/vpnpool/.unlock-running' _ "$tag" >/dev/null 2>&1 &
		echo $! > /tmp/vpnpool/.unlock-running   # record worker PID -> clear_stale_lock frees it the instant it dies
		echo '{"running":true,"started":true}'
		;;
	unlock_result)
		if [ -f /tmp/vpnpool/.unlock-running ]; then
			echo '{"running":true}'
		elif [ -f /tmp/vpnpool/.unlock-result.json ]; then
			jq '. + {running:false}' /tmp/vpnpool/.unlock-result.json 2>/dev/null || echo '{"running":false,"ok":false}'
		else
			echo '{"running":false}'
		fi
		;;
	add_auto_domain)
		# manual "this site is blocked" -> add to the adaptive proxy-route list
		d=$(echo "$input" | jq -r '.domain // ""' | tr 'A-Z' 'a-z' | sed 's,^https\?://,,; s,/.*$,,')
		if [ -n "$d" ] && ! uci -q get vpnpool.routing.auto_domain | tr ' ' '\n' | grep -Fxq "$d"; then
			uci add_list vpnpool.routing.auto_domain="$d"; uci commit vpnpool; signal_reload
		fi
		echo '{"ok":true}'
		;;
	del_auto_domain)
		d=$(echo "$input" | jq -r '.domain // ""')
		[ -n "$d" ] && { uci del_list vpnpool.routing.auto_domain="$d" 2>/dev/null; uci commit vpnpool; signal_reload; }
		echo '{"ok":true}'
		;;
	run_adaptive)
		# trigger one adaptive-routing scan now (background; it self-guards on the toggle)
		setsid sh -c '/usr/libexec/vpnpool/adaptive.sh' >/dev/null 2>&1 &
		echo '{"ok":true,"started":true}'
		;;
	speedtest)
		# real throughput test for ONE node — runs in the background (it briefly
		# routes router traffic through the node), poll speedtest_result.
		tag=$(echo "$input" | jq -r '.tag // ""')
		[ -n "$tag" ] || { echo '{"error":"no tag"}'; exit 0; }
		# Low-memory guard: on a 16 MB router an extra curl+jq burst can push an
		# already-tight box into OOM and kill sing-box. Refuse (with a clear message)
		# unless there is at least speedtest_min_mem_kb of available RAM.
		MINKB=$(uci -q get vpnpool.main.speedtest_min_mem_kb); [ -n "$MINKB" ] || MINKB=8192
		AVAIL=$(awk '/^MemAvailable:/{print $2; found=1} END{if(!found) exit 1}' /proc/meminfo 2>/dev/null)
		[ -n "$AVAIL" ] || AVAIL=$(awk '/^MemFree:/{f=$2}/^Buffers:/{b=$2}/^Cached:/{c=$2}END{print f+b+c}' /proc/meminfo 2>/dev/null)
		if [ -n "$AVAIL" ] && [ "$AVAIL" -lt "$MINKB" ]; then
			echo "{\"ok\":false,\"lowmem\":true,\"avail_kb\":${AVAIL:-0},\"need_kb\":$MINKB}"; exit 0
		fi
		mkdir -p /tmp/vpnpool
		clear_stale_lock /tmp/vpnpool/.speedtest-running 180   # don't let a killed test block forever
		if [ -f /tmp/vpnpool/.speedtest-running ]; then echo '{"running":true,"already":true}'; exit 0; fi
		: > /tmp/vpnpool/.speedtest-running
		rm -f /tmp/vpnpool/.speedtest-result.json
		setsid sh -c '/usr/libexec/vpnpool/speedtest.sh "$1"; rm -f /tmp/vpnpool/.speedtest-running' _ "$tag" >/dev/null 2>&1 &
		echo $! > /tmp/vpnpool/.speedtest-running   # record worker PID -> clear_stale_lock frees it the instant it dies
		echo '{"running":true,"started":true}'
		;;
	speedtest_result)
		if [ -f /tmp/vpnpool/.speedtest-running ]; then
			echo '{"running":true}'
		elif [ -f /tmp/vpnpool/.speedtest-result.json ]; then
			jq '. + {running:false}' /tmp/vpnpool/.speedtest-result.json 2>/dev/null || echo '{"running":false,"ok":false}'
		else
			echo '{"running":false}'
		fi
		;;
	set_domains)
		uci -q delete vpnpool.routing.domain
		echo "$input" | jq -r '.domains[]? // empty' | while read -r d; do
			[ -n "$d" ] && uci add_list vpnpool.routing.domain="$d"
		done
		uci commit vpnpool
		signal_reload
		echo '{"ok":true}'
		;;
	*)
		echo '{"error":"unknown method"}'
		;;
	esac
	;;
esac
