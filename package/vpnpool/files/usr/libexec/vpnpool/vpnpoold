#!/bin/sh
# vpnpool control-plane daemon (real).
# Orchestrates: fetch subscription -> build sing-box config -> run sing-box ->
# bring routing up (whole-LAN selective, coexists with podkop). Then supervises
# sing-box and periodically refreshes the subscription. On TERM it tears routing
# down and stops sing-box. Auto-ping + failover between nodes is done by the
# sing-box "urltest" outbound; this daemon supervises and refreshes.
. /usr/libexec/vpnpool/lib.sh

SB_PIDFILE=/var/run/vpnpool-singbox.pid
LIBEXEC=/usr/libexec/vpnpool

start_singbox() {
	sing-box run -c "$SB_CONF" -D "$SB_DATA" >> "$SB_DATA/sing-box.log" 2>&1 &
	echo $! > "$SB_PIDFILE"
	log "sing-box started pid=$(cat "$SB_PIDFILE")"
}

singbox_alive() {
	local p
	p=$(cat "$SB_PIDFILE" 2>/dev/null)
	[ -n "$p" ] && kill -0 "$p" 2>/dev/null
}

cleanup() {
	log "stopping: removing routing and sing-box"
	"$LIBEXEC/route.sh" down
	[ -f "$SB_PIDFILE" ] && kill "$(cat "$SB_PIDFILE")" 2>/dev/null
	rm -f "$SB_PIDFILE"
	log "stopped cleanly"
	exit 0
}

# USR1 = rebuild config from cache + manual nodes and hot-reload sing-box.
# Sent by the LuCI backend after manual node / domain edits so they apply live.
reload_config() {
	log "reload (USR1): rebuilding config"
	if "$LIBEXEC/build.sh"; then
		[ -f "$SB_PIDFILE" ] && kill "$(cat "$SB_PIDFILE")" 2>/dev/null
		sleep 1
		start_singbox
		log "reloaded: sing-box restarted"
	else
		log "reload: build failed, keeping current config"
	fi
}

# USR2 = re-fetch all sources, then rebuild + hot-reload (source/subscription edits).
refetch_config() {
	log "refetch (USR2): fetching sources"
	"$LIBEXEC/fetch.sh"
	reload_config
}

trap cleanup TERM INT
trap reload_config USR1
trap refetch_config USR2

mkdir -p "$SB_DATA"
log "vpnpoold starting (whole-LAN selective, coexist with podkop)"

# initial subscription + config
"$LIBEXEC/fetch.sh" || log "initial fetch failed (will use cache if present)"
if ! "$LIBEXEC/build.sh"; then
	log "FATAL: could not build initial config; exiting"
	exit 1
fi

start_singbox
sleep 3
"$LIBEXEC/route.sh" up
log "routing is UP"

REFRESH=$(interval_seconds)
LAST=$(date +%s)

# main supervise/refresh loop. sleep in bg + wait so TERM is handled promptly.
while : ; do
	sleep 15 & wait $!

	if ! singbox_alive; then
		log "sing-box not running, restarting"
		start_singbox
		sleep 2
	fi

	REFRESH=$(interval_seconds)
	NOW=$(date +%s)
	if [ $(( NOW - LAST )) -ge "$REFRESH" ]; then
		LAST=$NOW
		log "periodic subscription refresh"
		if "$LIBEXEC/fetch.sh" && "$LIBEXEC/build.sh"; then
			[ -f "$SB_PIDFILE" ] && kill "$(cat "$SB_PIDFILE")" 2>/dev/null
			sleep 1
			start_singbox
			log "subscription refreshed, sing-box reloaded"
		else
			log "refresh failed, keeping current config"
		fi
	fi
done
