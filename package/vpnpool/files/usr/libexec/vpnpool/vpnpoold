#!/bin/sh
# vpnpool control-plane daemon (real).
# Orchestrates: fetch subscription -> build sing-box config -> run sing-box ->
# bring routing up (whole-LAN selective, coexists with podkop). Then supervises
# sing-box and periodically refreshes the subscription. On TERM it tears routing
# down and stops sing-box. Auto-ping + failover between nodes is done by the
# sing-box "urltest" outbound; this daemon supervises and refreshes.
. /usr/libexec/vpnpool/lib.sh

SB_PIDFILE=/var/run/vpnpool-singbox.pid
LIBEXEC=/usr/libexec/vpnpool

SB_LOG="$SB_DATA/sing-box.log"
LOG_CAP=524288   # 512 KiB — keep the volatile /tmp log bounded

cap_log() {
	[ -f "$SB_LOG" ] && [ "$(wc -c < "$SB_LOG" 2>/dev/null || echo 0)" -gt "$LOG_CAP" ] && : > "$SB_LOG"
	return 0
}

# Stop our sing-box and WAIT until it's really gone before returning. The old code
# did `kill; sleep 1; start` — if the old process hadn't released tproxy :1603 and the
# cache.db lock within 1s, the NEW instance died with "address already in use" /
# "initialize cache-file: timeout", the supervisor restarted it, and it crash-looped.
# Match OUR sing-box only (by pidfile and by our own -c config path) so we never touch
# podkop's sing-box.
kill_singbox() {
	# NOTE: busybox `pkill -f` did NOT reliably match the full cmdline here (it left
	# instances alive -> orphans piled up, held :1603, and the crash loop / "imports
	# don't activate" followed). Iterate the PIDs `pgrep -f` reports and kill each
	# explicitly — that works.
	local p i pids
	i=0
	while :; do
		pids=$(pgrep -f "sing-box run -c $SB_CONF" 2>/dev/null)
		[ -z "$pids" ] && break
		i=$((i + 1))
		for p in $pids; do
			if [ "$i" -ge 5 ]; then kill -9 "$p" 2>/dev/null; else kill "$p" 2>/dev/null; fi
		done
		[ "$i" -ge 12 ] && break
		sleep 1
	done
	rm -f "$SB_PIDFILE"
	sleep 1   # let the kernel release the listening sockets before a re-bind
}

_do_start_singbox() {
	kill_singbox   # ensure no previous/orphaned instance holds :1603 or the cache lock
	cap_log
	# 9>&- : close the flock fd in the child, otherwise the backgrounded sing-box
	# INHERITS the lock fd and holds it for its whole lifetime — the next
	# start_singbox would then block forever on flock and never reload the config.
	sing-box run -c "$SB_CONF" -D "$SB_DATA" >> "$SB_LOG" 2>&1 9>&- &
	echo $! > "$SB_PIDFILE"
}

# Serialise restarts with a lock: the USR1/USR2 signal handlers and the main
# supervise loop can both call start_singbox; without a lock two of them raced and
# spawned overlapping sing-box instances that fought over :1603 -> crash loop.
# timestamp of the last sing-box (re)start — the watchdog uses it for its warm-up
# grace window so it never restarts a tunnel that is merely still picking a node.
SB_STARTED=0
start_singbox() {
	if command -v flock >/dev/null 2>&1; then
		( flock 9; _do_start_singbox; ) 9>/var/run/vpnpool-sb.lock
	else
		_do_start_singbox
	fi
	SB_STARTED=$(date +%s)
	log "sing-box started pid=$(cat "$SB_PIDFILE" 2>/dev/null)"
}

singbox_alive() {
	local p
	p=$(cat "$SB_PIDFILE" 2>/dev/null)
	[ -n "$p" ] && kill -0 "$p" 2>/dev/null
}

# the node actually carrying traffic (resolve selector 'auto' to the urltest pick)
current_node() {
	local p sel
	p=$(curl -s -m3 "http://$CLASH_API/proxies" 2>/dev/null)
	sel=$(echo "$p" | jq -r '.proxies.proxy.now // ""' 2>/dev/null)
	if [ -z "$sel" ] || [ "$sel" = "auto" ]; then
		echo "$p" | jq -r '.proxies.auto.now // ""' 2>/dev/null
	else
		echo "$sel"
	fi
}

# ---- two-way Telegram control bot ----
# The bot (tgbot.sh) is NOT forked/supervised here any more. It runs as its OWN procd
# instance (see /etc/init.d/vpnpool), so procd is its single supervisor: it reliably
# kills the bot on stop/restart and respawns it on crash. The old fork-as-background-child
# model orphaned the bot whenever this daemon was SIGKILLed (OOM, or procd's
# SIGTERM->SIGKILL on restart) — the orphan kept long-polling getUpdates while the next
# daemon spawned a second one, and Telegram's one-poller-per-bot rule made the two race
# (409 Conflict) so the bot "answered every other message". Moving it under procd removes
# that failure class at the root.

# ---- preferred-node soft pin with switch-back ----
# If preferred_node is set (and the user hasn't manually pinned a node and
# auto_switch is on): stick to the preferred node while it's reachable; when it
# dies, hand control to urltest "auto"; when it recovers, switch back. A small
# bad-streak counter avoids flapping.
PREF_BAD=0
PREF_GONE=0
preferred_check() {
	local pref sel asw p delay nowsel
	pref=$(uci -q get vpnpool.main.preferred_node)
	[ -n "$pref" ] || return 0
	sel=$(uci -q get vpnpool.main.selected_node); [ -n "$sel" ] && return 0  # manual pin wins
	asw=$(uci -q get vpnpool.main.auto_switch); [ "$asw" = "0" ] && return 0
	p=$(curl -s -m3 "http://$CLASH_API/proxies" 2>/dev/null)
	echo "$p" | jq -e '.proxies' >/dev/null 2>&1 || return 0   # clash API not ready — skip this cycle
	nowsel=$(echo "$p" | jq -r '.proxies.proxy.now // ""' 2>/dev/null)
	# Pin points to a tag that no longer exists (node removed / renamed / subscription changed
	# its #tag). Clear the orphaned pin after a few cycles so a stale 📌 doesn't linger forever
	# (the counter guards against a transient one-off miss).
	if ! echo "$p" | jq -e --arg t "$pref" '.proxies[$t]' >/dev/null 2>&1; then
		PREF_GONE=$((PREF_GONE + 1))
		if [ "$PREF_GONE" -ge 4 ]; then
			uci -q delete vpnpool.main.preferred_node; uci commit vpnpool
			PREF_GONE=0
			log "preferred node $pref no longer exists -> cleared stale pin"
		fi
		return 0
	fi
	PREF_GONE=0
	delay=$(echo "$p" | jq -r --arg t "$pref" '(.proxies[$t].history // []) | last | .delay // 0' 2>/dev/null)
	# Respect the service-accuracy dead-filter: NEVER pin a node it demoted (one that "pings"
	# but fails the user's services — e.g. a Reality node that connects but carries no data).
	# If the preferred node is in the dead set, treat it as down: hand over to auto and don't
	# re-pin (even if its clash-delay history flaps positive) until it leaves the dead set.
	if [ "$(uci -q get vpnpool.main.dead_filter)" != "0" ] && [ -f /tmp/vpnpool/.dead_tags.json ] \
	   && grep -Fq "\"$pref\"" /tmp/vpnpool/.dead_tags.json 2>/dev/null; then
		# A node demoted to the dead set is a SUSTAINED failure (failed the service check
		# dead_filter_strikes times in a row), not a transient blip — so don't just hand the
		# selector to auto, CLEAR the pin entirely (the 📌 goes away). A brief outage that
		# hasn't reached the dead set still keeps the pin + switches back on recovery (below).
		[ "$nowsel" = "$pref" ] && curl -s -m5 -X PUT "http://$CLASH_API/proxies/proxy" --data '{"name":"auto"}' >/dev/null 2>&1
		uci -q delete vpnpool.main.preferred_node; uci commit vpnpool
		PREF_BAD=0
		log "preferred node $pref is in the dead set -> unpinned and handed over to auto"
		return 0
	fi
	if [ -n "$delay" ] && [ "$delay" -gt 0 ] 2>/dev/null; then
		PREF_BAD=0
		if [ "$nowsel" != "$pref" ]; then
			curl -s -m5 -X PUT "http://$CLASH_API/proxies/proxy" --data "{\"name\":\"$pref\"}" >/dev/null 2>&1
			log "preferred node healthy -> switch back to $pref"
		fi
	else
		PREF_BAD=$((PREF_BAD + 1))
		if [ "$PREF_BAD" -ge 2 ] && [ "$nowsel" = "$pref" ]; then
			curl -s -m5 -X PUT "http://$CLASH_API/proxies/proxy" --data '{"name":"auto"}' >/dev/null 2>&1
			log "preferred node $pref down -> hand over to auto"
		fi
	fi
}

# ---- tunnel self-heal watchdog ----
# Catches the rare state where sing-box is ALIVE by pid but its urltest is stuck —
# every probe timing out for a long time while WAN is fine, recoverable only by a
# process restart. The supervisor's pid check alone never notices that.
#
# CRITICAL TUNING LESSON (2026-06-11): the first cut fired far too eagerly and created
# a restart LOOP — after every (re)start urltest needs ~60s to pick a working node, so
# the e2e probe fails during warm-up; counting those failures tripped a restart, which
# reset the warm-up, which failed again... Each restart also wipes the urltest delay
# history, so the dashboard showed "0 pings" and traffic blipped every few minutes on a
# tunnel that was actually FINE. The cure is: (1) a GRACE period after each start during
# which the watchdog never counts a strike; (2) treat the tunnel as alive if ANY of
# several probe attempts/URLs succeeds (intermittent flap != dead); (3) require a long
# run of confirmed-dead checks and a long cooldown so we only ever act on a genuine,
# sustained outage — never on warm-up or a flaky-but-working pool.
WD_BAD=0
WD_LIMIT=8        # confirmed-dead checks (each does 3 attempts) before acting
WD_COOLDOWN=1800  # >= 30 min between self-heals — the real bug was hours-long, not flaps
WD_GRACE=180      # after a (re)start, give urltest this long to warm up before judging
WD_LAST=0

# one tunnel probe through the test-mixed inbound (which egresses via the active node).
# The self-heal now keys on the SAME user-configured services as the node-quality filter
# (check_probe_urls): the tunnel is "alive" if the active node can actually REACH any of
# them. A reachable host answers with SOME HTTP code (200/204/301/404 — the path is just
# /generate_204); an over-quota / service-blocked exit can't connect at all (curl yields
# 000), which is exactly the "pings but the service is dead" state we want to heal.
probe_tunnel_once() {
	local tp u code
	tp=$(uci -q get vpnpool.main.test_port); [ -n "$tp" ] || tp=1605
	for u in $(check_probe_urls); do
		code=$(curl -s -o /dev/null -m6 --proxy "http://127.0.0.1:$tp" -w '%{http_code}' "$u" 2>/dev/null)
		case "$code" in ""|000) ;; *) return 0 ;; esac
	done
	return 1
}

watchdog_check() {
	local now
	[ -n "$(uci -q get vpnpool.main.selected_node)" ] && { WD_BAD=0; return 0; }
	now=$(date +%s)
	# grace window after a (re)start: never judge a tunnel that is still warming up
	[ $(( now - SB_STARTED )) -lt "$WD_GRACE" ] && { WD_BAD=0; return 0; }
	# 3 attempts spread over ~6s — a single flap must not count as down
	if probe_tunnel_once || { sleep 3; probe_tunnel_once; } || { sleep 3; probe_tunnel_once; }; then
		WD_BAD=0; return 0
	fi
	# probe failed all attempts — only OUR problem if WAN itself is up
	probe_wan() { curl -s -o /dev/null -m6 -w '%{http_code}' http://cp.cloudflare.com/generate_204 2>/dev/null; }
	[ "$(probe_wan)" = "204" ] || { WD_BAD=0; return 0; }
	WD_BAD=$((WD_BAD + 1))
	if [ "$WD_BAD" -ge "$WD_LIMIT" ] && [ $(( now - WD_LAST )) -ge "$WD_COOLDOWN" ]; then
		WD_BAD=0; WD_LAST=$now
		log "watchdog: tunnel dead ${WD_LIMIT}x (every probe) while WAN is up — self-healing (sing-box restart)"
		tg_notify "🩺 vpnpool: tunnel stuck, self-healing (sing-box restart)"
		kill_singbox
		rm -f "$SB_DATA/cache.db"   # a stale urltest/selector cache must not re-pin the dead state
		start_singbox
	fi
}

cleanup() {
	log "stopping: removing routing and sing-box"
	tg_notify "🔴 vpnpool: stopped"
	"$LIBEXEC/route.sh" down
	kill_singbox
	log "stopped cleanly"
	exit 0
}

# Bring routing up and report HONESTLY. route.sh exits non-zero when nft fails to apply
# the table (missing kernel module, ruleset error) — in that case traffic is NOT going
# through the VPN. Logging "routing is UP" unconditionally masked a dead tunnel in the
# logs/diagnostics, so check the exit code and say what actually happened.
routing_up() {
	if "$LIBEXEC/route.sh" up; then
		log "routing is UP"
		return 0
	fi
	log "routing FAILED to apply (nft) — traffic is NOT going through the VPN"
	return 1
}

# USR1 = rebuild config from cache + manual nodes and hot-reload sing-box.
# Sent by the LuCI backend after manual node / domain edits so they apply live.
reload_config() {
	log "reload (USR1): rebuilding config + routing"
	if "$LIBEXEC/build.sh"; then
		start_singbox   # stops the old instance and waits for the port/lock to free
		# re-apply routing so per-client / ipv6 / coexist / domain edits take effect
		"$LIBEXEC/route.sh" down
		routing_up
		log "reload complete (sing-box reloaded)"
	else
		log "reload: build failed, keeping current config"
	fi
}

# USR2 = re-fetch all sources, then rebuild + hot-reload (source/subscription edits).
refetch_config() {
	log "refetch (USR2): fetching sources"
	"$LIBEXEC/fetch.sh"
	reload_config
}

trap cleanup TERM INT
trap reload_config USR1
trap refetch_config USR2

mkdir -p "$SB_DATA"
log "vpnpoold starting (whole-LAN selective, coexist with podkop)"
kill_singbox   # clear any orphaned sing-box left by a previously crashed daemon

# initial subscription + config, with soft retry (e.g. WAN not ready at boot) —
# never give up, so the service self-heals once connectivity appears.
while : ; do
	"$LIBEXEC/fetch.sh" || log "fetch failed (will use cache if present)"
	if "$LIBEXEC/build.sh"; then
		break
	fi
	log "initial build failed (no nodes/cache yet), retrying in 15s"
	sleep 15 & wait $!
done

start_singbox
sleep 3
routing_up
tg_notify "🟢 vpnpool: routing is up"

REFRESH=$(interval_seconds)
LAST=$(date +%s)
SB_FAILS=0        # consecutive supervisor restarts of a dead sing-box (for crash-loop backoff)
LAST_NODE=""
SNAP_LAST=0
SNAP_EVERY=1800   # auto-snapshot reachable nodes at most every 30 min (self-guards on the toggle)
ADAPT_LAST=0
ADAPT_EVERY=600   # adaptive-routing scan at most every 10 min (self-guards on the toggle)

# ---- dead-node auto-filter (opt-in, on by default) -------------------------------
# Periodically run nodecheck.sh in the BACKGROUND: it e2e-probes every node through
# the clash delay API and demotes ones that reach nothing for a sustained run from the
# auto/urltest pool (it self-signals USR1 on a change to rebuild). Backgrounded so a
# multi-node sweep never stalls supervision; a grace window after each (re)start avoids
# judging a still-warming-up pool (same lesson as the watchdog).
DEADCHK_LAST=0
DEADCHK_EVERY=600   # at most every 10 min
DEADCHK_GRACE=120   # let urltest warm up after a (re)start before probing
node_quality_check() {
	[ "$(uci -q get vpnpool.main.dead_filter)" = "0" ] && return 0   # on by default (config default '1')
	singbox_alive || return 0
	local now; now=$(date +%s)
	[ $(( now - DEADCHK_LAST )) -ge "$DEADCHK_EVERY" ] || return 0
	[ $(( now - SB_STARTED )) -lt "$DEADCHK_GRACE" ] && return 0
	DEADCHK_LAST=$now
	setsid sh -c "$LIBEXEC/nodecheck.sh" >/dev/null 2>&1 &
}

# main supervise/refresh loop. sleep in bg + wait so TERM is handled promptly.
while : ; do
	sleep 15 & wait $!
	cap_log

	if ! singbox_alive; then
		SB_FAILS=$(( SB_FAILS + 1 ))
		log "sing-box not running, restarting (consecutive: $SB_FAILS)"
		start_singbox
		# Crash-loop backoff: if sing-box keeps dying right after start (e.g. a config that
		# passes `check` but faults at runtime), don't hot-loop every 15 s — back off so the
		# router stays responsive and logs aren't flooded. Resets once it stays alive.
		if [ "$SB_FAILS" -ge 3 ]; then
			bo=$(( SB_FAILS * 10 )); [ "$bo" -gt 120 ] && bo=120
			log "sing-box crash-looping — backing off ${bo}s"
			sleep "$bo" & wait $!
		else
			sleep 2
		fi
	else
		SB_FAILS=0
	fi

	# (the Telegram control bot is a separate procd instance — procd supervises it)

	# preferred-node soft pin + switch-back
	preferred_check

	# end-to-end tunnel health: restart sing-box if it's alive-but-stuck
	watchdog_check

	# auto-snapshot reachable nodes into the persistent saved store (opt-in)
	NOWS=$(date +%s)
	if [ "$(uci -q get vpnpool.main.auto_snapshot)" = "1" ] && [ $(( NOWS - SNAP_LAST )) -ge "$SNAP_EVERY" ]; then
		SNAP_LAST=$NOWS
		"$LIBEXEC/snapshot.sh" 2>/dev/null
	fi

	# adaptive routing scan (opt-in): runs in the background so a slow probe never
	# stalls supervision; it self-guards on the toggle and signals USR1 if it changed.
	if [ "$(uci -q get vpnpool.main.adaptive_routing)" = "1" ] && [ $(( NOWS - ADAPT_LAST )) -ge "$ADAPT_EVERY" ]; then
		ADAPT_LAST=$NOWS
		setsid sh -c "$LIBEXEC/adaptive.sh" >/dev/null 2>&1 &
	fi

	# dead-node auto-filter: demote nodes that e2e-probe as carrying no traffic
	node_quality_check

	# detect node change (failover / manual switch) and notify
	NODE=$(current_node)
	if [ -n "$NODE" ] && [ "$NODE" != "$LAST_NODE" ]; then
		[ -n "$LAST_NODE" ] && { log "active node -> $NODE"; tg_notify "🔁 vpnpool: switched to $NODE"; }
		LAST_NODE="$NODE"
	fi

	REFRESH=$(interval_seconds)
	NOW=$(date +%s)
	if [ $(( NOW - LAST )) -ge "$REFRESH" ]; then
		LAST=$NOW
		log "periodic subscription refresh"
		if "$LIBEXEC/fetch.sh" && "$LIBEXEC/build.sh"; then
			start_singbox   # stops the old instance and waits for the port/lock to free
			log "subscription refreshed, sing-box reloaded"
		else
			log "refresh failed, keeping current config"
		fi
		# subscription expiry warning
		EXP=$(cat "$CONF_DIR/sub.expire" 2>/dev/null)
		if [ -n "$EXP" ]; then
			DAYS=$(( (EXP - $(date +%s)) / 86400 ))
			[ "$DAYS" -ge 0 ] && [ "$DAYS" -le 3 ] && tg_notify "⚠️ vpnpool: subscription expires in ${DAYS}d"
		fi
		# subscription quota warning: alert once per refresh when <10% remains
		USAGE=$(cat "$CONF_DIR/sub.usage" 2>/dev/null)
		if [ -n "$USAGE" ]; then
			QTOT=$(echo "$USAGE" | awk '{print $3+0}')
			QUSED=$(echo "$USAGE" | awk '{print $1+$2}')
			if [ "${QTOT:-0}" -gt 0 ] 2>/dev/null; then
				QLEFT=$(( QTOT - QUSED ))
				QPCT=$(( QLEFT * 100 / QTOT ))
				QGB=$(awk -v b="$QLEFT" 'BEGIN{printf "%.1f", b/1073741824}')
				[ "$QPCT" -ge 0 ] && [ "$QPCT" -le 10 ] && tg_notify "⚠️ vpnpool: subscription quota low — ${QGB} GB (${QPCT}%) left"
			fi
		fi
	fi
done
