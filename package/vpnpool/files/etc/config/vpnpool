# vpnpool - control-plane over sing-box (analog of v2RayTun / Happ)
# Coexists with podkop (separate sing-box instance). Editable via uci / LuCI.
# NOTE: stage 1 skeleton - the daemon does not route any traffic yet.

config vpnpool 'main'
	option enabled '0'
	option mode 'selective'
	option subscription_url ''
	# Extra FULL subscriptions, bulk-merged into the pool like the primary one
	# (quota/expiry are read only from the primary). Managed via the UI.
	# list extra_sub 'https://...'
	option subscription_ua 'v2rayNG/1.8.5'
	option subscription_interval '6h'
	# Fallback liveness URL for sing-box urltest when check_services is empty.
	option health_url 'http://cp.cloudflare.com/generate_204'
	# Service-accuracy check — THE single node-quality criterion. The actual (often
	# blocked) services the VPN must make work THROUGH each node. Every node is probed
	# against these; one that can't reach ALL of them for dead_filter_strikes cycles is
	# dropped from the auto/urltest pool (still manually selectable). The SAME set drives
	# active-node selection (urltest url), failover and the self-heal watchdog, so the
	# whole stack agrees on "working". Space/newline-separated; a bare host is probed as
	# http://<host>/generate_204, a full URL is used as-is. Editable in the UI.
	option check_services 'www.youtube.com'
	option failover_interval '60'
	option failover_tolerance '50'
	option auto_switch '1'
	# persisted manual node pick (empty = AUTO/urltest); set by the UI "Use" button
	option selected_node ''
	# preferred node: soft pin with switch-back (empty = pure auto/urltest)
	option preferred_node ''
	# IPv6 policy: block (fail-closed) | off | proxy
	option ipv6 'block'
	# Kill-switch: fail-closed for IPv4 in full-tunnel (exclude) mode (opt-in)
	option killswitch '0'
	# DNS-leak guard: route LAN DNS through the tunnel (opt-in)
	option dns_protect '0'
	# Per-client routing: all | exclude (listed bypass) | include (only listed).
	# Clients are IPv4 addresses, e.g.:  list client '192.168.1.50'
	option client_mode 'all'
	# Saved nodes: links promoted from the subscription into a persistent store so
	# they stay usable after the subscription expires (managed via the UI ⭐ button).
	# list saved_node 'vless://...'
	# Auto-snapshot: periodically persist the currently-reachable nodes into the
	# saved store (bounded to auto_snapshot_max) so a working fallback survives
	# subscription expiry. Opt-in.
	option auto_snapshot '0'
	option auto_snapshot_max '20'
	# Scheduler (HH:MM, router local time): off/on the service + refresh subscription
	option sched_enabled '0'
	option sched_on ''
	option sched_off ''
	option sched_refresh ''
	# On-demand per-node speed test target (sized download endpoint)
	option speedtest_url 'https://speed.cloudflare.com/__down?bytes=10000000'
	# Anti-DPI TLS fragmentation (sing-box route-options). Levels: off / on
	# (tls_fragment — split the ClientHello so plaintext SNI DPI can't match) /
	# aggressive (also tls_record_fragment). Defeats BASIC filtering, not robust
	# censorship (for TSPU use zapret). Needs sing-box >= 1.12; ignored if
	# unsupported. Opt-in. (legacy values '0'=off, '1'=on are still accepted.)
	option antidpi 'off'
	# Adaptive routing: auto-detect domains blocked for a DIRECT connection and route
	# them through the proxy (stored in routing.auto_domain). Opt-in.
	option adaptive_routing '0'
	option adaptive_max_per_run '8'
	# Minimum available RAM (kB) required to run a speed test — guards tiny (16 MB)
	# routers from OOM-killing sing-box during the test.
	option speedtest_min_mem_kb '8192'
	# Dead-node auto-filter: periodically e2e-probe every node (against check_services
	# above) through the clash delay API; a node that fails to reach ALL of them for
	# dead_filter_strikes cycles in a row is dropped from the auto/urltest pool (still
	# manually selectable). Catches "TCP-pings / opens a CDN but the wanted service is
	# dead" nodes (expired-sub placeholders, over-quota / service-blocked exits). On by
	# default. Set to '0' to keep every node in the pool regardless.
	option dead_filter '1'
	option dead_filter_strikes '3'
	# Per-cycle probe retries: a node counts as reaching a service if ANY of these back-to-back
	# clash-delay attempts succeeds. Absorbs the intermittent COLD-handshake flakiness of
	# Reality/Vision nodes (a working node can miss a single probe, then a retry succeeds) so a
	# usable node isn't flapped into "unreachable"; a genuinely dead node fails every attempt.
	option dead_filter_tries '3'
	# Max concurrent TCP probes in the build-time health prefilter. Bounded so a large
	# subscription doesn't fork hundreds of curls at once and OOM sing-box on a 16 MB
	# router. Default 16 (in-code) if unset.
	# option prefilter_concurrency '16'
	# Telegram alerts (failover / subscription / lifecycle)
	option telegram_enabled '0'
	option telegram_token ''
	option telegram_chat ''
	# Two-way control bot (/status /nodes /switch /on /off /refresh)
	option telegram_control '0'
	# Reach Telegram through the tunnel (api.telegram.org is blocked in RU)
	option telegram_via_proxy '1'
	# --- non-colliding resources (discovered; MUST differ from podkop/zapret) ---
	# podkop: mark 0x100000, table podkop(pri105), tproxy :1602, clash :9090
	# zapret: mark 0x20000000 / ct 0x40000000
	option fwmark '0x400000'
	option route_table '142'
	option route_priority '106'
	option tproxy_port '1603'
	option test_port '1605'
	option clash_api '127.0.0.1:9091'
	option singbox_config '/etc/vpnpool/sing-box.json'
	option log_level 'warn'
	# lan_if empty = auto-detect (portable). coexist: auto|on|off — yield traffic
	# already marked by podkop/other proxies so we don't double-intercept it.
	option lan_if ''
	option coexist 'auto'

# Selective routing lists. Starter set mirrors podkop; fully editable.
config routing 'routing'
	list community 'telegram'
	list community 'russia_inside'
	# auto_domain: domains auto-detected as blocked-for-direct by adaptive routing
	# (always routed through the proxy when adaptive_routing=1). Managed via the UI.
	# list auto_domain 'example.com'

# Manual VLESS nodes (in addition to the subscription). Example:
# config node
#	option link 'vless://...#name'
#	option enabled '1'
